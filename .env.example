# IdeaCritic — Environment Variables
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Tavily Search API key for RAG market data (https://app.tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# MongoDB Atlas connection string (https://cloud.mongodb.com)
MONGO_CONNECTION_STRING=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
